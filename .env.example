# Bancos locais novos usam pgvector/pgvector:pg17 e o volume postgres17_data.
# Nunca reutilize neste serviço um volume criado por PG16. PostgreSQL sem vector
# não atende às migrations atuais. Estas variáveis configuram o banco novo.
POSTGRES_DB=seo_ledger
POSTGRES_USER=seo
POSTGRES_PASSWORD=replace-with-a-local-password

# URL usada pela aplicação. Aplique URL encoding à senha quando necessário.
DATABASE_URL=postgresql+asyncpg://seo:replace-with-a-local-password@postgres:5432/seo_ledger
REDIS_URL=redis://redis:6379/0
CREDENTIAL_MASTER_KEY=replace-with-a-fernet-key
# Em development/test os defaults locais e a documentação da API continuam
# habilitados. Em production, /docs, /redoc e /openapi.json não são registrados,
# e todos os requisitos abaixo devem ser definidos com valores reais de deploy.
APP_ENV=development
FRONTEND_ORIGIN=http://localhost:3000
ADMIN_API_TOKEN=replace-with-a-strong-random-secret
SUPERIOR_SKILLS_MODE=shadow
APP_COMMIT_SHA=unversioned
APP_BUILD_VERSION=development
APP_SOURCE_DIGEST=unversioned
SUPERIOR_SKILLS_PATH=/app/skills/superior
LEARNED_SKILL_STABILITY_THRESHOLD=3
LEARNED_SKILL_MIN_INDEPENDENT_ARTICLES=2
QUALITY_MIN_OVERALL_SCORE=0.75
QUALITY_MIN_AXIS_SCORE=0.55
QUALITY_MIN_CLAIM_OVERLAP=0.12
QUALITY_MAX_DUPLICATE_SCORE=0.90
QUALITY_MIN_WORD_COUNT=800
QUALITY_MAX_WORD_COUNT=1100
QUALITY_MIN_APPROVED_FACTS=10
QUALITY_MIN_H2_COUNT=4
QUALITY_MIN_H3_COUNT=0
QUALITY_MAX_SENTENCE_WORDS=30
CONTENT_SIMILARITY_WARNING_THRESHOLD=0.72
CONTENT_DUPLICATE_THRESHOLD=0.90
AGENT_TASK_DATA_MAX_CHARACTERS=400000
# Limites preventivos para todas as tentativas LLM registradas no run.
MAX_PIPELINE_COST_USD=0.80
MAX_AGENT_COST_USD=0.40
# Timeouts separados evitam conexão pendurada e dão tempo para respostas longas.
PROVIDER_CONNECT_TIMEOUT_SECONDS=15
PROVIDER_READ_TIMEOUT_SECONDS=90
PIPELINE_DISPATCH_BATCH_SIZE=50
PIPELINE_DISPATCH_CLAIM_TTL_SECONDS=120
PIPELINE_DISPATCH_DELIVERY_TIMEOUT_SECONDS=900
PIPELINE_DISPATCH_RETRY_BASE_SECONDS=30
PIPELINE_DISPATCH_RETRY_MAX_SECONDS=300
PIPELINE_DISPATCH_INTERVAL_SECONDS=60
READINESS_TIMEOUT_SECONDS=3
OPERATIONAL_HEARTBEAT_INTERVAL_SECONDS=5
OPERATIONAL_HEARTBEAT_MAX_AGE_SECONDS=20
OPERATIONAL_HEARTBEAT_TTL_SECONDS=30

# Editorial Intelligence V3 is executable but opt-in; apply migration 0031 first.
EDITORIAL_PIPELINE_V3_ENABLED=false
EDITORIAL_PIPELINE_V3_EXECUTION_ENABLED=false

# Editorial Intelligence V3 (enable only after migration 0031)
V3_MAX_RESEARCH_TASKS=16
V3_MAX_SEARCH_QUERIES=32
V3_SEARCH_RESULTS_PER_QUERY=5
V3_MAX_SOURCE_DOCUMENTS=48
V3_MAX_SEARCH_PROVIDER_REQUESTS=96
V3_MAX_SEARCH_PROVIDER_RETRIES=32
V3_MAX_SEARCH_ESTIMATED_CREDITS=96
V3_SOURCE_DISCOVERY_TIMEOUT_SECONDS=240
V3_MAX_SOURCE_FETCHES=64
V3_MAX_SOURCE_RECOVERY_ROUNDS=2
V3_MIN_CANDIDATE_RELEVANCE=0.18
V3_MAX_DOCUMENTS_PER_RESEARCH_TASK=6
V3_MIN_APPROVED_CLAIMS=18
V3_MIN_CLAIMS_PER_METHOD=3
V3_MIN_STEPS_PER_METHOD=3
V3_WRITER_REPAIR_ATTEMPTS=1
V3_MIN_WORD_COUNT=1800
V3_MAX_WORD_COUNT=3500
