+def test_source_coverage_allows_synthesis_when_only_task_level_diversity_is_missing():
+    task = _task(
+        "task_mechanism",
+        node_id="mechanism",
+        role=EvidenceRole.mechanism,
+        goal="Explicar o mecanismo fisiológico da germinação com fonte científica.",
+        required_source_roles=["scientific_review"],
+        minimum_sources=2,
+        critical=True,
+    )
+    document = _document(
+        "https://science-one.example/research",
+        title="Estudo primário sobre o mecanismo de germinação",
+        text="A absorção de água reativa o metabolismo e antecede a emissão da radícula.",
+        role=SourceRole.scientific_primary,
+        allowed_roles=[EvidenceRole.mechanism],
+    )
+    key = canonicalize_url(str(document.canonical_url))
+
+    report = SourceCoverageService().evaluate(
+        tasks=[task],
+        documents=[document],
+        source_task_map={key: [task.task_id]},
+    )
+
+    assert report.status == "incomplete"
+    assert report.synthesis_ready is True
+    assert report.suggested_blocking_code == "V3_SOURCE_DIVERSITY_INSUFFICIENT"
+    assert report.task_reports[0].reason_codes == (
+        "independent_source_diversity_insufficient",
+    )
+
+
