+def test_graph_advances_to_synthesis_for_provisional_source_coverage():
+    async def noop(state):
+        return state
+
+    nodes = V3PipelineNodes(
+        **{name: noop for name in V3PipelineNodes.__annotations__}
+    )
+    state = V3PipelineState(
+        project_id=uuid4(),
+        pipeline_run_id=uuid4(),
+        stage=V3Stage.source_coverage_gate,
+        source_coverage_report={
+            "status": "incomplete",
+            "synthesis_ready": True,
+            "suggested_blocking_code": "V3_SOURCE_DIVERSITY_INSUFFICIENT",
+        },
+    )
+
+    result = EditorialIntelligenceV3Graph(nodes)._transition(state)
+
+    assert result.stage == V3Stage.knowledge_synthesizer
+
